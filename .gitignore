cat > .gitignore << 'EOF'
# Virtual environment
EPG/

# Old data
data/old data - MYCN errors/

# Old results
old results/

# All Word, PowerPoint, and Word lock files
*.docx
*.pptx
~$*
*.tmp

# Scratch files
stuff.txt
data_checking.py
visualize.ipynb
.ipynb_checkpoints/

# Data folder docs
data/data_loader.txt

# Old scripts
depmap/depmap_ranking.py
kocak/kocak_ranking.py
kocak/kocak.py

# Duplicate Excel exports
results/*.xlsx

# Old GD one-sample results
results/depmap_GD_ADRN.csv
results/depmap_GD_MES.csv

# VS Code
.vscode/

# Python cache
__pycache__/
*.pyc
EOF